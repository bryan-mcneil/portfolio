# Next.js metadata routes export as extensionless files (e.g. /opengraph-image,
# /projects/<slug>/opengraph-image). Force the image type so social scrapers
# accept them.
<Files "opengraph-image">
  ForceType image/png
</Files>

# Long cache for fingerprinted build assets and media. /_next/static filenames
# are content-hashed, so a year is safe; media files change rarely.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType video/mp4 "access plus 1 month"
</IfModule>
